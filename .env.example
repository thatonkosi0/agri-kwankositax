PORT=7331
SELF_HOSTED_MODE=true
DISABLE_SIGNUP=true

# Database. On Supabase/serverless use the pooled URL for DATABASE_URL and the
# direct (non-pooled) URL for DIRECT_URL. For a plain Postgres, set both the same.
DATABASE_URL="postgresql://user@localhost:5432/taxhacker"
DIRECT_URL="postgresql://user@localhost:5432/taxhacker"

# Storage backend: "local" (filesystem, self-hosted/Docker) or "supabase"
# (Supabase Storage, required on Vercel/serverless where the FS is ephemeral).
STORAGE_BACKEND="local"
UPLOAD_PATH="./data/uploads"                 # used when STORAGE_BACKEND=local
SUPABASE_URL=""                              # used when STORAGE_BACKEND=supabase
SUPABASE_SERVICE_ROLE_KEY=""                 # service/secret key (server-side only);
SUPABASE_SECRET_KEY=""                       #   set EITHER this or the line above (sb_secret_...)
SUPABASE_STORAGE_BUCKET="uploads"            # create this bucket in Supabase Storage

# You can put it here or the app will ask you to enter it
OPENAI_MODEL_NAME="gpt-4o-mini"
OPENAI_API_KEY=""  # "sk-..."

GOOGLE_MODEL_NAME="gemini-2.5-flash"
GOOGLE_API_KEY=""

MISTRAL_MODEL_NAME="mistral-medium-latest"
MISTRAL_API_KEY=""

# Auth Config
BETTER_AUTH_SECRET="random-secret-key"  # please use any long random string here

# Stripe Configuration
STRIPE_SECRET_KEY=""  # "sk_live_..." or "sk_test_..."
STRIPE_WEBHOOK_SECRET=""  # "whsec_..."

# Resend Configuration (optional, use if you want to send emails)
RESEND_API_KEY=""  # "re_..."
RESEND_AUDIENCE_ID=""  # "aud_..."
RESEND_FROM_EMAIL="TaxHacker <user@localhost>"
