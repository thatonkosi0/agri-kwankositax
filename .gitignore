# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# data directory
/data/*

# dependencies (root and nested, e.g. learn-claude-code/*/node_modules)
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist
/release

# misc
.DS_Store
*.pem
.vscode

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all variants except the committed example
.env*
!.env.example

# local logs / scratch
*.log

# separate nested sub-project, not part of this app's deploy
learn-claude-code/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# databases
prisma/client
pgdata
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.db-journal
# Sentry Config File
.env.sentry-build-plugin
